    <ImageView android:id="@+id/tracker07" android:layout_width="0dp" android:layout_height="0dp"
        android:contentDescription="@string/tracker7of12" android:tag="7" android:padding="2dp"
        app:layout_constraintBottom_toTopOf="@+id/guidelineH0"
        app:layout_constraintEnd_toStartOf="@+id/tracker08"
        app:layout_constraintStart_toEndOf="@+id/tracker06"
        app:layout_constraintTop_toTopOf="@+id/guidelineHneg1"
        app:srcCompat="@drawable/zz_incomplete"/>
    <ImageView android:id="@+id/tracker08" android:layout_width="0dp" android:layout_height="0dp"
        android:contentDescription="@string/tracker8of12" android:tag="8" android:padding="2dp"
        app:layout_constraintBottom_toTopOf="@+id/guidelineH0"
        app:layout_constraintEnd_toStartOf="@+id/tracker09"
        app:layout_constraintStart_toEndOf="@+id/tracker07"
        app:layout_constraintTop_toTopOf="@+id/guidelineHneg1"
        app:srcCompat="@drawable/zz_incomplete"/>
    <ImageView android:id="@+id/tracker09" android:layout_width="0dp" android:layout_height="0dp"
        android:contentDescription="@string/tracker9of12" android:tag="9" android:padding="2dp"
        app:layout_constraintBottom_toTopOf="@+id/guidelineH0"
        app:layout_constraintEnd_toStartOf="@+id/tracker10"
        app:layout_constraintStart_toEndOf="@+id/tracker08"
        app:layout_constraintTop_toTopOf="@+id/guidelineHneg1"
        app:srcCompat="@drawable/zz_incomplete"/>
    <ImageView android:id="@+id/tracker10" android:layout_width="0dp" android:layout_height="0dp"
        android:contentDescription="@string/tracker10of12" android:tag="10" android:padding="2dp"
        app:layout_constraintBottom_toTopOf="@+id/guidelineH0"
        app:layout_constraintEnd_toStartOf="@+id/tracker11"
