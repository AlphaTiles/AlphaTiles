<?xml version="1.0" encoding="utf-8"?>
<!--
    cameroon.xml  –  Segmenting Game layout  (revised)
    =====================================================
    CHANGE LOG vs original:
      XML #1  wordImage shrunk 30%:  H2 moved from 0.36 → 0.276
      XML #2  wordText grown  50%:   H3 moved from 0.44 → 0.396
      XML #3  Selector buttons 50% smaller inside same column space:
                added guidelineV1b (0.046) and guidelineV2b (0.119)
                selectors now use V1b→V2b instead of V1→V2
      XML #4  Tile columns 0–5 made equal width:
                V3–V14 recalculated; each col = 0.129 wide with 0.01 gaps
      XML #5  Grid rows 0–3 made equal height:
                H4 = 0.406; each row = 0.119 tall; H5–H10 recalculated

    Vertical zones (% of screen height):
      guidelineHneg1  0.01    top of status bar
      guidelineH0     0.06    bottom of status bar
      guidelineH1     0.08    top of wordImage
      guidelineH2     0.276   bottom of wordImage / top of wordText   [XML #1]
      guidelineH3     0.396   bottom of wordText                      [XML #2]
      guidelineH4     0.406   top of grid row 0                       [XML #5]
      guidelineH5     0.525   boundary row 0 / row 1                  [XML #5]
      guidelineH6     0.535   top of grid row 1                       [XML #5]
      guidelineH7     0.654   boundary row 1 / row 2                  [XML #5]
      guidelineH8     0.664   top of grid row 2                       [XML #5]
      guidelineH9     0.783   boundary row 2 / row 3                  [XML #5]
      guidelineH10    0.793   top of grid row 3                       [XML #5]
      guidelineH11    0.91    bottom of grid row 3
      guidelineHSys1  0.93    top of bottom nav
      guidelineHSys2  0.99    bottom of bottom nav

    Horizontal zones (% of screen width):
      guidelineV1    0.01    left margin
      guidelineV1b   0.046   left edge of selector button  (inner)   [XML #3]
      guidelineV2b   0.119   right edge of selector button (inner)   [XML #3]
      guidelineV2    0.155   right edge of selector column (outer, unchanged)
      guidelineV3    0.165   left edge of tile col 0                 [XML #4]
      guidelineV4    0.294   right edge of tile col 0                [XML #4]
      guidelineV5    0.304   left edge of tile col 1                 [XML #4]
      guidelineV6    0.433   right edge of tile col 1                [XML #4]
      guidelineV7    0.443   left edge of tile col 2                 [XML #4]
      guidelineV8    0.572   right edge of tile col 2                [XML #4]
      guidelineV9    0.582   left edge of tile col 3                 [XML #4]
      guidelineV10   0.711   right edge of tile col 3                [XML #4]
      guidelineV11   0.721   left edge of tile col 4                 [XML #4]
      guidelineV12   0.850   right edge of tile col 4                [XML #4]
      guidelineV13   0.860   left edge of tile col 5                 [XML #4]
      guidelineV14   0.99    right margin / right edge tile col 5    [XML #4]

    Grid ID scheme:
      selector{R}          – row R selector TextView (R = 0..3)
      tileBtn_{R}_{C}      – row R, tile-position C ImageView (C = 0..5)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cameroonCL"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".Cameroon">

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--  TOP STATUS BAR  (gameNumberView | challengeLevelView | trackers | points) -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <TextView
        android:id="@+id/spacerLeft1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:tag="SL1"
        app:layout_constraintBottom_toTopOf="@+id/guidelineH0"
        app:layout_constraintEnd_toStartOf="@+id/spacerLeft2"
        app:layout_constraintStart_toStartOf="@id/guidelineV1"
        app:layout_constraintTop_toTopOf="@+id/guidelineHneg1"/>

    <TextView
