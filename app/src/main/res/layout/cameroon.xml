        android:tag="0"
        app:layout_constraintBottom_toTopOf="@+id/guidelineH5"
        app:layout_constraintEnd_toStartOf="@+id/guidelineV2b"
        app:layout_constraintStart_toStartOf="@+id/guidelineV1b"
        app:layout_constraintTop_toTopOf="@+id/guidelineH4"
